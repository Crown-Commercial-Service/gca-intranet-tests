# UI base (your tests already use this)
PW_BASE_URL=http://localhost:8080

# Path to the WordPress docker repo (where the compose files live)
WP_DOCKER_CWD=

# Theme under wp-content/themes
WP_THEME=gca-intranet

# Tell the test harness we're using the parallel docker compose stack
PARALLEL_LOCAL=true

# Ensure all docker compose calls use the same env file as the WP repo
WP_ENV_FILE=.env